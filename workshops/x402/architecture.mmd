graph TB
    subgraph NVM["Nevermined Platform"]
        direction TB
        subgraph Services[" "]
            direction LR
            Plans["<b>Plans API</b><br/>create · subscribe · balance"]
            Perms["<b>Permissions (x402)</b><br/>generate · verify · settle"]
            Deleg["<b>Delegation Service</b><br/>create · validate card · charge"]
        end
        SC["<b>Smart Contracts (Base Chain)</b><br/>ERC-1155 Credits: mint / burn / transfer"]
