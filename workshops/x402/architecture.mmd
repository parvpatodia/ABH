    end

    Seller["<b>Seller Agent</b><br/>middleware<br/>verify() · settle()"]
    Buyer["<b>Buyer Agent</b><br/>SDK calls<br/>get_token()"]
    Stripe["<b>Stripe (fiat)</b><br/>charge() → mint()"]

    Seller --> Perms
    Buyer --> Perms
    Buyer --> Plans
    Stripe --> Deleg
    Deleg --> SC

    style NVM fill:#f0f4ff,stroke:#334,stroke-width:2px
    style SC fill:#e8f5e9,stroke:#2e7d32
    style Seller fill:#fff3e0,stroke:#e65100
    style Buyer fill:#e3f2fd,stroke:#1565c0
    style Stripe fill:#fce4ec,stroke:#c62828
